---
import { getCollection } from 'astro:content';
import Print from '../../layouts/Print.astro';
import { getModuleMeta } from '../../lib/modules';

export async function getStaticPaths() {
  const entries = await getCollection('modules');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
const meta = getModuleMeta(entry.id.replace(/\.md$/, ''));
const source = (entry.data.sources ?? [])[0] ?? '';
---
<Print
  title={entry.data.title}
  icon={meta?.icon ?? ''}
  source={source}
  slug={slug}
>
  <Content />
</Print>
