---
import { getCollection } from 'astro:content';
import Print from '../../../layouts/Print.astro';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const entries = await getCollection('workflows');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await entry.render();

const svgPath = join(process.cwd(), 'public', 'charts', `${slug}.svg`);
const hasSvg = existsSync(svgPath);
const svgContent = hasSvg ? readFileSync(svgPath, 'utf-8') : null;

const source = (entry.data.sources ?? [])[0] ?? '';
---
<Print
  title={entry.data.title}
  icon=""
  source={source}
  slug={`workflow/${slug}`}
>
  {hasSvg && svgContent && (
    <div style="column-span: all; margin-bottom: 1em; border: 1px solid #e5e7eb; border-radius: 4px; padding: 8px; overflow: hidden;">
      <Fragment set:html={svgContent} />
    </div>
  )}
  <Content />
</Print>
