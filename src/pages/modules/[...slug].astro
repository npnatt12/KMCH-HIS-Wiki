---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PrintButton from '../../components/PrintButton.astro';
import ModuleChip from '../../components/ModuleChip.astro';
import ImageGalleryButton from '../../components/ImageGalleryButton.astro';
import { getModuleMeta } from '../../lib/modules';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const entries = await getCollection('modules');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
const meta = getModuleMeta(entry.id.replace(/\.md$/, ''));
const relatedModuleTags = (entry.data.tags ?? []).filter(
  (t: string) => t !== 'module' && !t.includes(' ')
);

// Load screenshot manifest
let moduleImages: { file: string; thumb: string; section: string }[] = [];
try {
  const manifestPath = join(process.cwd(), 'public', 'screenshots', 'manifest.json');
  const manifest = JSON.parse(readFileSync(manifestPath, 'utf-8'));
  if (manifest[slug]) {
    moduleImages = manifest[slug].map((img: any) => ({
      file: img.file,
      thumb: img.thumb,
      section: img.section || '',
    }));
  }
} catch {}
---
<Base title={entry.data.title} showBackLink={true}>
  <div class="mb-4 flex items-center justify-between flex-wrap gap-2">
    <div class="flex items-center gap-3">
      {meta && (
        <span class="text-3xl">{meta.icon}</span>
      )}
      <div>
        <h1 class="text-2xl font-bold text-gray-900">{entry.data.title}</h1>
        {meta && (
          <p class="text-sm text-gray-500">{meta.nameTh}</p>
        )}
      </div>
    </div>
    <div class="flex items-center gap-2 flex-wrap">
      {moduleImages.length > 0 && (
        <ImageGalleryButton images={moduleImages} moduleSlug={slug} />
      )}
      <PrintButton slug={slug} />
    </div>
  </div>

  {relatedModuleTags.length > 0 && (
    <div class="flex flex-wrap gap-2 mb-4">
      <span class="text-xs text-gray-400 self-center">โมดูลที่เกี่ยวข้อง:</span>
      {relatedModuleTags.map((tag: string) => (
        <ModuleChip name={tag} />
      ))}
    </div>
  )}

  <div
    data-pagefind-body
    class="prose prose-sm max-w-none
           prose-headings:text-gray-800 prose-h2:text-lg prose-h2:font-bold prose-h2:border-b prose-h2:border-gray-200 prose-h2:pb-1 prose-h2:mb-3
           prose-table:text-xs prose-th:bg-gray-50 prose-td:py-1
           prose-a:text-blue-700 prose-a:no-underline hover:prose-a:underline
           prose-code:bg-gray-100 prose-code:px-1 prose-code:rounded prose-code:text-xs">
    <Content />
  </div>
</Base>
