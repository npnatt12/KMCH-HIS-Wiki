---
import { getCollection } from 'astro:content';
import ArticleV2 from '../../layouts/ArticleV2.astro';
import Breadcrumb from '../../components/article/Breadcrumb.astro';
import MetaStrip from '../../components/article/MetaStrip.astro';
import RelatedSection from '../../components/article/RelatedSection.astro';
import PrintButton from '../../components/PrintButton.astro';
import ModuleChip from '../../components/ModuleChip.astro';
import ImageGalleryButton from '../../components/ImageGalleryButton.astro';
import { getModuleMeta } from '../../lib/modules';
import { getRelated } from '../../lib/article-helpers';
import { readFileSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const entries = await getCollection('modules');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { Content } = await entry.render();

const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
const meta = getModuleMeta(entry.id.replace(/\.md$/, ''));
const relatedModuleTags = (entry.data.tags ?? []).filter(
  (t: string) => t !== 'module' && !t.includes(' ')
);

// Load screenshot manifest
let moduleImages: { file: string; thumb: string; section: string }[] = [];
try {
  const manifestPath = join(process.cwd(), 'public', 'screenshots', 'manifest.json');
  const manifest = JSON.parse(readFileSync(manifestPath, 'utf-8'));
  if (manifest[slug]) {
    moduleImages = manifest[slug].map((img: any) => ({
      file: img.file,
      thumb: img.thumb,
      section: img.section || '',
    }));
  }
} catch {}

const related = await getRelated('modules', slug, entry.data.roles);
---
<ArticleV2 title={entry.data.title} route="module">
  <Breadcrumb items={[
    { label: 'Modules', href: '/' },
    { label: entry.data.title },
  ]} />

  <article class="kmch-prose">
    <div class="not-prose flex items-start justify-between gap-4 mb-2">
      <div class="flex items-center gap-3">
        {meta && (
          <span class="text-4xl leading-none">{meta.icon}</span>
        )}
        <div>
          <h1 class="kmch-prose text-[clamp(2rem,4vw,2.6rem)] font-semibold leading-tight m-0" style="background-image: linear-gradient(90deg, #C2362F 0%, #D9492C 50%, #E87D2C 100%); background-repeat: no-repeat; background-size: 96px 4px; background-position: 0 100%; padding-bottom: 0.6rem;">{entry.data.title}</h1>
          {meta && (
            <p class="text-sm text-[var(--color-ink-muted)] mt-1">{meta.nameTh}</p>
          )}
        </div>
      </div>
      <div class="flex items-center gap-2 flex-wrap flex-shrink-0">
        {moduleImages.length > 0 && (
          <ImageGalleryButton images={moduleImages} moduleSlug={slug} />
        )}
        <PrintButton slug={slug} />
      </div>
    </div>

    <MetaStrip
      type="module"
      roles={entry.data.roles}
      verifiedOn={entry.data['verified-on-uat']}
      sources={entry.data.sources}
      updated={entry.data.updated}
    />

    {relatedModuleTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mb-6 not-prose">
        <span class="text-xs text-[var(--color-ink-muted)] self-center">โมดูลที่เกี่ยวข้อง:</span>
        {relatedModuleTags.map((tag: string) => (
          <ModuleChip name={tag} />
        ))}
      </div>
    )}

    <Content />
  </article>

  <RelatedSection items={related} />
</ArticleV2>
