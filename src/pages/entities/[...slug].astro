---
import { getCollection } from 'astro:content';
import ArticleV2 from '../../layouts/ArticleV2.astro';
import Breadcrumb from '../../components/article/Breadcrumb.astro';
import MetaStrip from '../../components/article/MetaStrip.astro';
import RelatedSection from '../../components/article/RelatedSection.astro';
import PDPABanner from '../../components/wiki/PDPABanner.astro';
import { getRelated } from '../../lib/article-helpers';
import { hasImages } from '../../lib/article-meta';

export async function getStaticPaths() {
  const entries = await getCollection('entities');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await entry.render();

const related = await getRelated('entities', slug!, entry.data.roles);
const showPDPA = entry.data['mock-data'] !== false && hasImages(entry.body);
---
<ArticleV2 title={entry.data.title} route="entity">
  <Breadcrumb items={[
    { label: 'Screens', href: '/' },
    { label: entry.data.title },
  ]} />

  <article class="kmch-prose">
    <h1>{entry.data.title}</h1>
    <MetaStrip
      type="entity"
      roles={entry.data.roles}
      verifiedOn={entry.data['verified-on-uat']}
      sources={entry.data.sources}
      updated={entry.data.updated}
    />

    {showPDPA && <PDPABanner />}

    <Content />
  </article>

  <RelatedSection items={related} />
</ArticleV2>
