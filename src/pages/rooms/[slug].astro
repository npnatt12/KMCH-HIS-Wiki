---
import BaseV2 from '../../layouts/BaseV2.astro';
import ArticleToolbar from '../../components/wiki/ArticleToolbar.astro';
import EyebrowPill from '../../components/ui/EyebrowPill.astro';
import { ROOMS } from '../../lib/rooms';

export function getStaticPaths() {
  return ROOMS.map((room) => ({ params: { slug: room.slug }, props: { room } }));
}

const { room } = Astro.props;
const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? 'https://kmch-wiki.vercel.app').href;
const statusLabel =
  room.status === 'uat-verified'
    ? `ยืนยันจาก UAT ${room.verifiedOn}`
    : room.status === 'source-backed'
      ? 'อ้างอิงจากคู่มือ/หน้า wiki ภาษาไทย'
      : 'รอ UAT confirmation';
---
<BaseV2 title={room.title}>
  <main class="mx-auto px-4 lg:px-6 py-8 lg:py-12 max-w-[920px]">
    <ArticleToolbar url={canonicalUrl} />

    <article>
      <a href="/rooms/" class="text-sm text-[var(--color-ink-muted)] hover:text-[var(--color-accent-primary)]">← All rooms</a>
      <div class="mt-6 border-b border-[var(--color-border)] pb-8">
        <EyebrowPill>{room.department} / ROOM MODE</EyebrowPill>
        <h1 class="mt-4 text-[clamp(2rem,4.6vw,3.1rem)] font-semibold tracking-tight" style={`color:${room.accent}`}>
          {room.titleTh}
        </h1>
        <p class="mt-1 text-lg text-[var(--color-ink-muted)]">{room.title}</p>
        <p class="mt-5 max-w-2xl text-[var(--color-ink-muted)]">{room.summary}</p>
        <div class="mt-6 flex flex-wrap gap-2 text-xs">
          <span class="px-3 py-1 rounded-full bg-[var(--color-accent-soft)] text-[var(--color-accent-primary)]">{statusLabel}</span>
          {room.staff.map((role) => (
            <span class="px-3 py-1 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">{role}</span>
          ))}
        </div>
      </div>

      <section class="py-8 border-b border-[var(--color-border)]">
        <h2 id="start-here" class="text-xl font-semibold">เริ่มที่นี่ / Start Here</h2>
        <ol class="mt-5 grid gap-3">
          {room.startHere.map((step, idx) => (
            <li class="flex gap-3 rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
              <span class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm font-semibold text-white" style={`background:${room.accent}`}>{idx + 1}</span>
              <span class="pt-0.5 text-sm leading-relaxed">{step}</span>
            </li>
          ))}
        </ol>
      </section>

      <section class="py-8 border-b border-[var(--color-border)]">
        <h2 id="screens-used" class="text-xl font-semibold">หน้าจอที่ใช้ / Screens Used</h2>
        <div class="mt-5 grid grid-cols-1 sm:grid-cols-2 gap-3">
          {room.screens.map((item) => (
            <a href={item.href} class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4 hover:bg-[var(--color-surface-tint)]">
              <span class="block text-sm font-semibold">{item.label}</span>
              {item.note && <span class="mt-1 block text-xs text-[var(--color-ink-muted)]">{item.note}</span>}
            </a>
          ))}
        </div>
      </section>

      <section class="py-8 border-b border-[var(--color-border)]">
        <h2 id="common-mistakes" class="text-xl font-semibold">ข้อผิดพลาดที่พบบ่อย / Common Mistakes</h2>
        <div class="mt-5 grid gap-3">
          {room.commonMistakes.map((item) => (
            <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
              <h3 class="text-sm font-semibold">{item.symptom}</h3>
              <p class="mt-2 text-sm text-[var(--color-ink-muted)]">{item.fix}</p>
              {item.href && <a href={item.href} class="mt-3 inline-block text-sm font-medium">เปิดหน้าอ้างอิง</a>}
            </div>
          ))}
        </div>
      </section>

      <section class="py-8 border-b border-[var(--color-border)]">
        <h2 id="handoff" class="text-xl font-semibold">ส่งต่อ / Handoff</h2>
        <div class="mt-5 grid gap-3">
          {room.handoffs.map((item) => (
            <div class="rounded-2xl border border-[var(--color-border)] bg-[var(--color-surface)] p-4">
              <div class="text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-muted)]">ถัดไป / Next</div>
              {item.href ? (
                <a href={item.href} class="mt-1 inline-block text-base font-semibold">{item.to}</a>
              ) : (
                <h3 class="mt-1 text-base font-semibold">{item.to}</h3>
              )}
              <p class="mt-2 text-sm text-[var(--color-ink-muted)]">{item.when}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="py-8 grid grid-cols-1 lg:grid-cols-2 gap-6">
        <div>
          <h2 class="text-xl font-semibold">Workflow ที่เกี่ยวข้อง</h2>
          <div class="mt-4 grid gap-2">
            {room.workflows.map((item) => (
              <a href={item.href} class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm hover:bg-[var(--color-surface-tint)]">{item.label}</a>
            ))}
          </div>
        </div>
        <div>
          <h2 class="text-xl font-semibold">Concept ที่เกี่ยวข้อง</h2>
          <div class="mt-4 grid gap-2">
            {room.concepts.map((item) => (
              <a href={item.href} class="rounded-xl border border-[var(--color-border)] bg-[var(--color-surface)] px-4 py-3 text-sm hover:bg-[var(--color-surface-tint)]">{item.label}</a>
            ))}
          </div>
        </div>
      </section>

      <section class="pb-4">
        <h2 class="text-xl font-semibold">คำค้นหา</h2>
        <div class="mt-4 flex flex-wrap gap-2">
          {room.searchTerms.map((term) => (
            <span class="rounded-full border border-[var(--color-border)] bg-[var(--color-surface-tint)] px-3 py-1 text-xs text-[var(--color-ink-muted)]">{term}</span>
          ))}
        </div>
      </section>
    </article>
  </main>
</BaseV2>
