---
import LandingV2 from '../../layouts/LandingV2.astro';
import EyebrowPill from '../../components/ui/EyebrowPill.astro';
import Card from '../../components/ui/Card.astro';
import Reveal from '../../components/ui/Reveal.astro';
import FooterV2 from '../../components/home/FooterV2.astro';
import { ROOMS } from '../../lib/rooms';

const futureRooms = [
  'Pharmacy Dispensing',
  'X-ray Register / Report',
  'ER Triage',
  'Ward / IPD Nursing',
  'OR / Recovery Room',
  'Telemedicine Admin',
  'Odoo Finance',
  'Odoo Procurement',
  'Odoo Inventory / Warehouse',
];
---
<LandingV2 title="Room Mode">
  <section class="pt-12 pb-12 lg:pt-20 lg:pb-16 border-b border-[var(--color-border)]"
           style="background: linear-gradient(180deg, var(--color-bg) 0%, color-mix(in srgb, var(--color-accent-soft) 36%, var(--color-bg)) 100%);">
    <div class="mx-auto px-4" style="max-width: min(calc(100% - 32px), 1080px);">
      <EyebrowPill>ห้องทำงาน / ROOM MODE</EyebrowPill>
      <h1 class="mt-4 text-[clamp(2rem,4.8vw,3rem)] font-semibold tracking-tight">เปิดคู่มือตามจุดบริการจริง</h1>
      <p class="mt-4 max-w-2xl text-[var(--color-ink-muted)]">
        Room Mode ใช้ภาษาไทยเป็นหลักจากคู่มือ/หน้า wiki เดิม แล้วสรุปเป็นขั้นตอนที่ใช้ ณ ห้องหรือเคาน์เตอร์จริง.
      </p>
      <div class="mt-8 flex flex-wrap gap-3 text-sm">
        <span class="px-4 py-2 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">{ROOMS.length} ห้องพร้อมใช้</span>
        <span class="px-4 py-2 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">QR + print ready</span>
        <span class="px-4 py-2 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">OPD + LAB</span>
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20">
    <div class="mx-auto px-4" style="max-width: min(calc(100% - 32px), 1080px);">
      <Reveal>
        <EyebrowPill>พร้อมใช้งาน / LIVE ROOMS</EyebrowPill>
        <h2 class="mt-4 text-[clamp(1.6rem,3.4vw,2.5rem)] font-semibold tracking-tight">การ์ดปฏิบัติงานตามห้อง</h2>
      </Reveal>
      <div class="mt-10 grid grid-cols-1 lg:grid-cols-3 gap-4">
        {ROOMS.map((room, idx) => (
          <Reveal delay={idx * 80}>
            <Card href={`/rooms/${room.slug}/`}>
              <div class="flex items-start justify-between gap-3">
                <div>
                  <p class="text-xs font-semibold uppercase tracking-[0.12em] text-[var(--color-ink-muted)]">{room.department}</p>
                  <h3 class="mt-2 text-lg font-semibold">{room.titleTh}</h3>
                  <p class="text-sm text-[var(--color-ink-muted)]">{room.title}</p>
                </div>
                <span class="w-3 h-3 rounded-full mt-1 shrink-0" style={`background:${room.accent}`}></span>
              </div>
              <p class="mt-4 text-sm text-[var(--color-ink-muted)] leading-relaxed">{room.summary}</p>
              <div class="mt-5 flex flex-wrap gap-2 text-xs">
                <span class="px-2.5 py-1 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">{room.startHere.length} ขั้นตอน</span>
                <span class="px-2.5 py-1 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">{room.screens.length} หน้าจอ</span>
                {room.verifiedOn ? (
                  <span class="px-2.5 py-1 rounded-full bg-[var(--color-accent-soft)] text-[var(--color-accent-primary)]">UAT {room.verifiedOn}</span>
                ) : (
                  <span class="px-2.5 py-1 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">จากคู่มือไทย</span>
                )}
              </div>
            </Card>
          </Reveal>
        ))}
      </div>
    </div>
  </section>

  <section class="py-16 lg:py-20 bg-[var(--color-bg-strong)]">
    <div class="mx-auto px-4" style="max-width: min(calc(100% - 32px), 1080px);">
      <Reveal>
        <EyebrowPill>ถัดไป / BACKLOG</EyebrowPill>
        <h2 class="mt-4 text-[clamp(1.4rem,3vw,2rem)] font-semibold tracking-tight">ห้องถัดไปหลังยืนยัน UAT</h2>
      </Reveal>
      <div class="mt-8 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-3">
        {futureRooms.map((name) => (
          <div class="rounded-2xl border border-dashed border-[var(--color-border-strong)] bg-[var(--color-surface)] px-4 py-3 text-sm text-[var(--color-ink-muted)]">
            {name}
          </div>
        ))}
      </div>
    </div>
  </section>

  <FooterV2 />
</LandingV2>
