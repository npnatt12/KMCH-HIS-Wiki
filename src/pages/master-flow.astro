---
import { ZONES, FLOW_MODULES, CONNECTIONS, SYSTEMS, ENTRY_POINTS, INTERFACES } from '../lib/hospital-flow-data';

// Build a lookup map for quick zone color access
const zoneColorMap: Record<string, string> = {};
ZONES.forEach(z => { zoneColorMap[z.id] = z.color; });

// Build module lookup
const moduleMap: Record<string, typeof FLOW_MODULES[0]> = {};
FLOW_MODULES.forEach(m => { moduleMap[m.slug] = m; });

// Helper to get zone by id
function getZone(id: string) {
  return ZONES.find(z => z.id === id)!;
}
---
<html lang="th">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Master Hospital Flow — KMCH HIS</title>
  <link rel="preload" href="/fonts/Sarabun-Regular.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/Sarabun-Bold.woff2" as="font" type="font/woff2" crossorigin />
  <style>
    @font-face {
      font-family: 'Sarabun';
      font-style: normal;
      font-weight: 400;
      font-display: swap;
      src: url('/fonts/Sarabun-Regular.woff2') format('woff2');
    }
    @font-face {
      font-family: 'Sarabun';
      font-style: normal;
      font-weight: 700;
      font-display: swap;
      src: url('/fonts/Sarabun-Bold.woff2') format('woff2');
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; overflow: hidden; }
    body {
      font-family: 'Sarabun', sans-serif;
      background: #0f172a;
      color: #e2e8f0;
    }

    /* Layout */
    .app { display: flex; flex-direction: column; height: 100vh; }
    .top-bar {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 10px 20px;
      background: #1e293b;
      border-bottom: 1px solid #334155;
      flex-shrink: 0;
      z-index: 10;
    }
    .top-bar h1 { font-size: 18px; font-weight: 700; color: #f1f5f9; }
    .top-bar-actions { display: flex; gap: 12px; align-items: center; }
    .top-bar a, .top-bar button {
      font-family: 'Sarabun', sans-serif;
      font-size: 13px;
      padding: 6px 14px;
      border-radius: 6px;
      text-decoration: none;
      cursor: pointer;
      border: 1px solid #475569;
      background: #1e293b;
      color: #cbd5e1;
      transition: background 0.15s;
    }
    .top-bar a:hover, .top-bar button:hover { background: #334155; }
    .version-chips {
      display: flex;
      gap: 6px;
      align-items: center;
    }
    .version-chip {
      font-size: 11px;
      padding: 3px 9px;
      border-radius: 14px;
      border: 1px solid #475569;
      background: #1e293b;
      color: #94a3b8;
      white-space: nowrap;
    }
    .version-chip-dot { display: inline-block; width: 8px; height: 8px; border-radius: 50%; margin-right: 6px; vertical-align: middle; }
    .version-chip.medhis { border-color: #22c55e; color: #86efac; }
    .version-chip.medhis .version-chip-dot { background: #22c55e; }
    .version-chip.odoo { border-color: #facc15; color: #fde68a; }
    .version-chip.odoo .version-chip-dot { background: #facc15; }
    .version-chip.patient-app { border-color: #ec4899; color: #fbcfe8; }
    .version-chip.patient-app .version-chip-dot { background: #ec4899; }
    .btn-print { background: #1e3a5f !important; border-color: #3b82f6 !important; color: #93c5fd !important; }

    .main-content {
      display: flex;
      flex: 1;
      overflow: hidden;
    }
    .flow-area {
      flex: 1;
      overflow-y: auto;
      padding: 32px 24px 48px;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    /* Info Panel */
    .info-panel {
      width: 300px;
      flex-shrink: 0;
      background: #1e293b;
      border-left: 1px solid #334155;
      overflow-y: auto;
      padding: 20px 16px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }
    .info-default { color: #64748b; text-align: center; padding-top: 40px; font-size: 14px; }
    .info-default .hint-icon { font-size: 36px; margin-bottom: 10px; }
    .info-module { display: none; }
    .info-module.active { display: flex; flex-direction: column; gap: 14px; }
    .info-entrypoint { display: flex; flex-direction: column; gap: 14px; }
    .info-module-header {
      display: flex;
      align-items: center;
      gap: 10px;
      padding-bottom: 12px;
      border-bottom: 1px solid #334155;
    }
    .info-module-icon { font-size: 28px; }
    .info-module-names h2 { font-size: 16px; font-weight: 700; color: #f1f5f9; margin: 0; }
    .info-module-names .name-th { font-size: 13px; color: #94a3b8; margin: 0; }
    .info-purpose { font-size: 13px; color: #cbd5e1; line-height: 1.6; }
    .info-system-line {
      display: flex;
      align-items: center;
      gap: 6px;
      font-size: 12px;
      color: #94a3b8;
      padding-bottom: 8px;
      margin-bottom: 4px;
      border-bottom: 1px solid #334155;
    }
    .info-system-line .system-dot { width: 8px; height: 8px; border-radius: 50%; }
    .info-system-line.medhis .system-dot { background: #22c55e; }
    .info-system-line.odoo .system-dot { background: #facc15; }
    .info-system-line.patient-app .system-dot { background: #ec4899; }
    .info-embedded-note {
      font-size: 11.5px;
      color: #cbd5e1;
      font-style: italic;
      padding: 4px 8px;
      background: #33415544;
      border-radius: 4px;
      margin-top: 2px;
    }
    .info-section-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #64748b;
      margin-bottom: 4px;
    }
    .info-list { list-style: none; padding: 0; }
    .info-list li {
      font-size: 12.5px;
      color: #cbd5e1;
      padding: 3px 0;
      padding-left: 14px;
      position: relative;
    }
    .info-list li::before {
      content: '';
      position: absolute;
      left: 0;
      top: 10px;
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #475569;
    }
    .info-step-list { list-style: none; padding: 0; counter-reset: step; }
    .info-step-list li {
      font-size: 12.5px;
      color: #cbd5e1;
      padding: 3px 0;
      padding-left: 22px;
      position: relative;
      counter-increment: step;
    }
    .info-step-list li::before {
      content: counter(step);
      position: absolute;
      left: 0;
      top: 2px;
      width: 16px;
      height: 16px;
      border-radius: 50%;
      background: #334155;
      font-size: 10px;
      font-weight: 700;
      text-align: center;
      line-height: 16px;
      color: #94a3b8;
    }
    .info-connected {
      display: flex;
      flex-wrap: wrap;
      gap: 6px;
    }
    .info-connected-chip {
      font-size: 11px;
      padding: 3px 8px;
      border-radius: 4px;
      background: #334155;
      color: #94a3b8;
      cursor: pointer;
      border: none;
      font-family: 'Sarabun', sans-serif;
      transition: background 0.15s;
    }
    .info-connected-chip:hover { background: #475569; color: #e2e8f0; }
    .info-wiki-link {
      display: inline-flex;
      align-items: center;
      gap: 4px;
      font-size: 13px;
      color: #60a5fa;
      text-decoration: none;
      padding-top: 4px;
    }
    .info-wiki-link:hover { text-decoration: underline; }

    /* Legend */
    .legend {
      margin-top: auto;
      padding-top: 16px;
      border-top: 1px solid #334155;
    }
    .legend-title {
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.05em;
      color: #64748b;
      margin-bottom: 8px;
    }
    .legend-items { display: flex; flex-direction: column; gap: 4px; }
    .legend-item { display: flex; align-items: center; gap: 8px; font-size: 12px; color: #94a3b8; }
    .legend-dot { width: 10px; height: 10px; border-radius: 3px; flex-shrink: 0; }

    /* Flow Elements */
    .flow-pill {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 10px 24px;
      border-radius: 24px;
      font-size: 14px;
      font-weight: 700;
      color: #fff;
    }
    .flow-pill-start { background: #16a34a; }
    .flow-pill-end { background: #16a34a; }

    .flow-arrow {
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 6px 0;
      color: #475569;
      font-size: 18px;
      line-height: 1;
    }
    .flow-arrow-line {
      width: 2px;
      height: 18px;
      background: #475569;
    }

    .flow-cross-arrow {
      display: flex;
      align-items: center;
      gap: 8px;
      width: 100%;
      max-width: 700px;
      padding: 8px 0;
      flex-wrap: wrap;
      justify-content: center;
    }
    .flow-cross-line {
      flex: 1;
      min-width: 30px;
      height: 0;
      border-top: 2px dashed #ec4899;
    }
    .flow-cross-line.gold { border-color: #facc15; }
    .interface-chip {
      font-size: 11px;
      padding: 4px 10px;
      border-radius: 14px;
      border: 1px solid #ec4899;
      background: #1e293b;
      color: #fbcfe8;
      text-decoration: none;
      font-family: 'Sarabun', sans-serif;
      white-space: nowrap;
      min-height: 24px;
      display: inline-flex;
      align-items: center;
    }
    .interface-chip.gold { border-color: #facc15; color: #fde68a; }
    .interface-chip:hover { background: #334155; }

    .flow-decision {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: 12px 28px;
      background: #854d0e;
      border: 2px solid #ca8a04;
      color: #fef08a;
      font-weight: 700;
      font-size: 14px;
      transform: rotate(0deg);
      border-radius: 8px;
      position: relative;
    }
    .flow-decision::before {
      content: '';
      position: absolute;
      inset: -4px;
      border: 2px solid #ca8a0466;
      border-radius: 12px;
    }

    /* Zone Box */
    .zone-box {
      border: 2px solid;
      border-radius: 12px;
      padding: 16px;
      min-width: 280px;
      max-width: 560px;
      width: 100%;
      position: relative;
    }
    .zone-header {
      display: flex;
      align-items: baseline;
      gap: 8px;
      margin-bottom: 12px;
    }
    .zone-label-en { font-size: 14px; font-weight: 700; }
    .zone-label-th { font-size: 12px; opacity: 0.7; }
    .zone-chips {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .zone-box.variant-patient {
      border-style: dashed;
      background: #50072422 !important;
    }
    .zone-box.variant-erp {
      border-style: dashed;
      background: #42200622 !important;
    }
    .entry-point-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      border: 2px solid #ec4899;
      background: #831843aa;
      color: #fce7f3;
      font-family: 'Sarabun', sans-serif;
      transition: border-color 0.15s, transform 0.1s;
    }
    .entry-point-chip:hover { transform: translateY(-1px); }
    .entry-point-chip.selected { border-color: #fff !important; }
    .entry-point-chip.system-external {
      border-color: #94a3b8;
      background: #33415588;
      color: #cbd5e1;
    }

    /* Module Chip */
    .module-chip {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 7px 14px;
      border-radius: 8px;
      font-size: 13px;
      font-weight: 700;
      cursor: pointer;
      border: 2px solid transparent;
      transition: border-color 0.15s, transform 0.1s;
      font-family: 'Sarabun', sans-serif;
      color: #fff;
    }
    .module-chip:hover { transform: translateY(-1px); }
    .module-chip.selected { border-color: #fff !important; }
    .module-chip[data-system="odoo"] {
      box-shadow: inset 4px 0 0 #facc15;
    }
    .module-chip[data-system="patient-app"] {
      box-shadow: inset 4px 0 0 #ec4899;
    }
    .module-chip[data-new="true"] {
      outline: 2px dashed #fde68a;
      outline-offset: 2px;
    }
    .module-chip-icon { font-size: 15px; }

    /* Split Row */
    .flow-split-row {
      display: flex;
      gap: 20px;
      width: 100%;
      max-width: 700px;
      justify-content: center;
    }
    .flow-split-row .zone-box { flex: 1; min-width: 0; }

    /* Arrows for split */
    .flow-split-arrows {
      display: flex;
      justify-content: center;
      gap: 200px;
      width: 100%;
      max-width: 700px;
    }

    /* ── Mobile Styles ── */
    @media (max-width: 768px) {
      .top-bar { padding: 8px 12px; }
      .top-bar h1 { font-size: 14px; }
      .top-bar-actions { gap: 6px; }
      .top-bar a, .top-bar button { font-size: 11px; padding: 5px 10px; }

      .main-content { position: relative; }

      .info-panel {
        position: fixed;
        top: 0;
        right: 0;
        bottom: 0;
        width: 280px;
        z-index: 100;
        transform: translateX(100%);
        transition: transform 0.25s ease;
        box-shadow: -4px 0 20px rgba(0,0,0,0.5);
      }
      .info-panel.open { transform: translateX(0); }

      .flow-area {
        padding: 20px 12px 40px;
        width: 100%;
      }

      .flow-split-row {
        flex-direction: column;
        align-items: center;
        gap: 0;
        max-width: 100%;
      }
      .flow-split-row .zone-box { min-width: 0; width: 100%; }
      .flow-split-row .zone-box + .zone-box { margin-top: 0; }

      /* Insert arrow between stacked split boxes */
      .flow-split-arrows { display: none; }
      .flow-arrow-mobile { display: flex; }
      .flow-split-row .flow-arrow-mobile {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 6px 0;
        color: #475569;
        font-size: 18px;
        line-height: 1;
      }
      .flow-split-row .flow-arrow-mobile .flow-arrow-line {
        width: 2px;
        height: 18px;
        background: #475569;
      }

      .zone-box { max-width: 100%; min-width: 0; }

      .module-chip { font-size: 12px; padding: 11px 12px; min-height: 44px; }
      .entry-point-chip { font-size: 12px; padding: 11px 12px; min-height: 44px; }

      .flow-decision { padding: 10px 18px; font-size: 13px; }

      .flow-pill { font-size: 13px; padding: 8px 18px; }

      .interface-chip { min-height: 44px; padding: 12px 14px; font-size: 12px; }
      .flow-cross-arrow { gap: 6px; }
    }

    @media (max-width: 480px) {
      .version-chip {
        font-size: 0;
        padding: 6px;
        line-height: 0;
      }
      .version-chip-dot { margin-right: 0; }
      .zone-box.variant-patient .zone-chips,
      .zone-box.variant-erp .zone-chips {
        flex-direction: column;
        align-items: stretch;
      }
    }

    /* Mobile panel overlay backdrop */
    .panel-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.5);
      z-index: 99;
    }
    .panel-backdrop.open { display: block; }

    /* Mobile toggle button */
    .mobile-info-toggle {
      display: none;
      position: fixed;
      bottom: 20px;
      right: 20px;
      z-index: 50;
      width: 48px;
      height: 48px;
      border-radius: 50%;
      background: #3b82f6;
      color: #fff;
      border: none;
      font-size: 22px;
      cursor: pointer;
      box-shadow: 0 4px 12px rgba(59,130,246,0.4);
      font-family: 'Sarabun', sans-serif;
    }
    @media (max-width: 768px) {
      .mobile-info-toggle { display: flex; align-items: center; justify-content: center; }
    }

    /* Mobile close button inside panel */
    .panel-close {
      display: none;
      align-self: flex-end;
      background: none;
      border: 1px solid #475569;
      color: #94a3b8;
      font-size: 18px;
      width: 32px;
      height: 32px;
      border-radius: 6px;
      cursor: pointer;
      font-family: 'Sarabun', sans-serif;
      flex-shrink: 0;
    }
    @media (max-width: 768px) {
      .panel-close { display: flex; align-items: center; justify-content: center; }
    }

    /* ── Print Styles ── */
    @media print {
      @page { size: A3 landscape; margin: 10mm; }
      html, body { height: auto; overflow: visible; }
      .top-bar { display: none !important; }
      .info-panel { display: none !important; }
      .mobile-info-toggle { display: none !important; }
      .panel-backdrop { display: none !important; }
      .flow-arrow-mobile { display: none !important; }
      .app { height: auto; }
      .main-content { height: auto; overflow: visible; }
      .flow-area {
        overflow: visible;
        padding: 10px;
      }
      body { background: #fff !important; color: #1e293b !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .flow-pill { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .zone-box { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .module-chip { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .version-chips { display: none !important; }
      .entry-point-chip { -webkit-print-color-adjust: exact; print-color-adjust: exact; border-color: #1e293b; }
      .interface-chip { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .flow-cross-line { border-color: #94a3b8 !important; }
      .zone-box.variant-patient,
      .zone-box.variant-erp { border-style: dashed !important; }
      .flow-decision { -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .flow-arrow { color: #94a3b8; }
      .flow-arrow-line { background: #94a3b8; }

      /* Print legend at bottom */
      .print-legend {
        display: flex !important;
        flex-wrap: wrap;
        gap: 12px 24px;
        justify-content: center;
        padding: 16px 0;
        margin-top: 20px;
        border-top: 1px solid #cbd5e1;
      }
      .print-legend-item {
        display: flex;
        align-items: center;
        gap: 6px;
        font-size: 11px;
        color: #475569;
      }
      .print-legend-dot {
        width: 10px;
        height: 10px;
        border-radius: 3px;
        -webkit-print-color-adjust: exact;
        print-color-adjust: exact;
      }
    }
    .print-legend { display: none; }
    .flow-arrow-mobile { display: none; }
  </style>
</head>
<body>
  <div class="app">
    <!-- Top Bar -->
    <div class="top-bar">
      <h1>Master Hospital Flow — KMCH HIS</h1>
      <div class="version-chips" aria-label="Systems">
        {SYSTEMS.map(s => (
          <span class={`version-chip ${s.id}`} title={s.version} aria-label={`${s.shortLabel} ${s.version}`}>
            <span class="version-chip-dot"></span>{s.label}
          </span>
        ))}
      </div>
      <div class="top-bar-actions">
        <button class="btn-print" onclick="window.print()">Print A3 Poster</button>
        <a href="/">Back to Wiki</a>
      </div>
    </div>

    <div class="main-content">
      <!-- Flow Area -->
      <div class="flow-area" id="flow-area">

        <!-- 1. Patient Touchpoints band -->
        {(() => {
          const z = ZONES.find(z => z.id === 'patient-touchpoints')!;
          return (
            <div class={`zone-box variant-${z.variant}`} style={`border-color: ${z.color};`}>
              <div class="zone-header">
                <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
              </div>
              <div class="zone-chips">
                {ENTRY_POINTS.map(ep => (
                  <button class={`entry-point-chip system-${ep.system}`} data-entrypoint={ep.slug}>
                    <span class="module-chip-icon">{ep.icon}</span>
                    {ep.nameEn}
                  </button>
                ))}
              </div>
            </div>
          );
        })()}

        <!-- Cross-system arrow: Patient → MEDHIS (pink) -->
        <div class="flow-cross-arrow" aria-label="Patient to MEDHIS">
          <span class="flow-cross-line"></span>
          {INTERFACES.filter(i => i.color === 'pink').map(i => (
            <span class="interface-chip" title={i.labelTh}>{i.label}</span>
          ))}
          <span class="flow-cross-line"></span>
        </div>

        <!-- 2. Registration Zone -->
        {(() => {
          const z = getZone('registration');
          return (
            <div class="zone-box" style={`border-color: ${z.color}; background: ${z.color}11;`}>
              <div class="zone-header">
                <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
              </div>
              <div class="zone-chips">
                {z.modules.map(slug => {
                  const m = moduleMap[slug];
                  return (
                    <button class="module-chip" data-slug={slug} data-system={m.system} data-new={m.isNew ? 'true' : 'false'} style={`background: ${z.color}33; color: ${z.color};`}>
                      <span class="module-chip-icon">{m.icon}</span>
                      {m.nameEn}
                    </button>
                  );
                })}
              </div>
            </div>
          );
        })()}

        <!-- Arrow -->
        <div class="flow-arrow">
          <div class="flow-arrow-line"></div>
          <span>&#x25BC;</span>
        </div>

        <!-- 3. Split: OPD / ER -->
        <div class="flow-split-row">
          {(() => {
            const z = getZone('outpatient');
            return (
              <div class="zone-box" style={`border-color: ${z.color}; background: ${z.color}11;`}>
                <div class="zone-header">
                  <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                  <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
                </div>
                <div class="zone-chips">
                  {z.modules.map(slug => {
                    const m = moduleMap[slug];
                    return (
                      <button class="module-chip" data-slug={slug} data-system={m.system} data-new={m.isNew ? 'true' : 'false'} style={`background: ${z.color}33; color: ${z.color};`}>
                        <span class="module-chip-icon">{m.icon}</span>
                        {m.nameEn}
                      </button>
                    );
                  })}
                </div>
              </div>
            );
          })()}
          <div class="flow-arrow-mobile">
            <div class="flow-arrow-line"></div>
            <span>&#x25BC;</span>
          </div>
          {(() => {
            const z = getZone('emergency');
            return (
              <div class="zone-box" style={`border-color: ${z.color}; background: ${z.color}11;`}>
                <div class="zone-header">
                  <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                  <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
                </div>
                <div class="zone-chips">
                  {z.modules.map(slug => {
                    const m = moduleMap[slug];
                    return (
                      <button class="module-chip" data-slug={slug} data-system={m.system} data-new={m.isNew ? 'true' : 'false'} style={`background: ${z.color}33; color: ${z.color};`}>
                        <span class="module-chip-icon">{m.icon}</span>
                        {m.nameEn}
                      </button>
                    );
                  })}
                </div>
              </div>
            );
          })()}
        </div>

        <!-- Dual arrows -->
        <div class="flow-split-arrows">
          <div class="flow-arrow">
            <div class="flow-arrow-line"></div>
            <span>&#x25BC;</span>
          </div>
          <div class="flow-arrow">
            <div class="flow-arrow-line"></div>
            <span>&#x25BC;</span>
          </div>
        </div>

        <!-- 4. Clinical Services -->
        {(() => {
          const z = getZone('clinical');
          return (
            <div class="zone-box" style={`border-color: ${z.color}; background: ${z.color}11;`}>
              <div class="zone-header">
                <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
              </div>
              <div class="zone-chips">
                {z.modules.map(slug => {
                  const m = moduleMap[slug];
                  return (
                    <button class="module-chip" data-slug={slug} data-system={m.system} data-new={m.isNew ? 'true' : 'false'} style={`background: ${z.color}33; color: ${z.color};`}>
                      <span class="module-chip-icon">{m.icon}</span>
                      {m.nameEn}
                    </button>
                  );
                })}
              </div>
            </div>
          );
        })()}

        <!-- Arrow -->
        <div class="flow-arrow">
          <div class="flow-arrow-line"></div>
          <span>&#x25BC;</span>
        </div>

        <!-- 5. Decision Diamond -->
        <div class="flow-decision">
          Admit? / Discharge?
        </div>

        <!-- Arrow -->
        <div class="flow-arrow">
          <div class="flow-arrow-line"></div>
          <span>&#x25BC;</span>
        </div>

        <!-- 6. Split: Inpatient / Discharge -->
        <div class="flow-split-row">
          {(() => {
            const z = getZone('inpatient');
            return (
              <div class="zone-box" style={`border-color: ${z.color}; background: ${z.color}11;`}>
                <div class="zone-header">
                  <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                  <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
                </div>
                <div class="zone-chips">
                  {z.modules.map(slug => {
                    const m = moduleMap[slug];
                    return (
                      <button class="module-chip" data-slug={slug} data-system={m.system} data-new={m.isNew ? 'true' : 'false'} style={`background: ${z.color}33; color: ${z.color};`}>
                        <span class="module-chip-icon">{m.icon}</span>
                        {m.nameEn}
                      </button>
                    );
                  })}
                </div>
              </div>
            );
          })()}
          <div class="flow-arrow-mobile">
            <div class="flow-arrow-line"></div>
            <span>&#x25BC;</span>
          </div>
          {(() => {
            const z = getZone('discharge');
            return (
              <div class="zone-box" style={`border-color: ${z.color}; background: ${z.color}11;`}>
                <div class="zone-header">
                  <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                  <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
                </div>
                <div class="zone-chips">
                  {z.modules.map(slug => {
                    const m = moduleMap[slug];
                    return (
                      <button class="module-chip" data-slug={slug} data-system={m.system} data-new={m.isNew ? 'true' : 'false'} style={`background: ${z.color}33; color: ${z.color};`}>
                        <span class="module-chip-icon">{m.icon}</span>
                        {m.nameEn}
                      </button>
                    );
                  })}
                </div>
              </div>
            );
          })()}
        </div>

        <!-- Dual arrows -->
        <!-- Dual arrows -->
        <div class="flow-split-arrows">
          <div class="flow-arrow">
            <div class="flow-arrow-line"></div>
            <span>&#x25BC;</span>
          </div>
          <div class="flow-arrow">
            <div class="flow-arrow-line"></div>
            <span>&#x25BC;</span>
          </div>
        </div>

        <!-- 7. Patient Discharged pill -->
        <div class="flow-pill flow-pill-end">
          <span>&#x1F3E0;</span> ผู้ป่วยกลับบ้าน (Discharged)
        </div>

        <!-- 8. Cross-system arrow: HIS → Odoo (gold) -->
        <div class="flow-cross-arrow" aria-label="MEDHIS to Odoo">
          <span class="flow-cross-line gold"></span>
          {INTERFACES.filter(i => i.color === 'gold').map(i => (
            i.workflowUrl
              ? <a class="interface-chip gold" href={i.workflowUrl} title={i.labelTh}>{i.label}</a>
              : <span class="interface-chip gold" title={i.labelTh}>{i.label}</span>
          ))}
          <span class="flow-cross-line gold"></span>
        </div>

        <!-- 9. Back-office band (Odoo) -->
        {(() => {
          const z = ZONES.find(z => z.id === 'back-office')!;
          return (
            <div class={`zone-box variant-${z.variant}`} style={`border-color: ${z.color};`}>
              <div class="zone-header">
                <span class="zone-label-en" style={`color: ${z.color};`}>{z.label}</span>
                <span class="zone-label-th" style={`color: ${z.color};`}>{z.labelTh}</span>
              </div>
              <div class="zone-chips">
                {z.modules.map(slug => {
                  const m = moduleMap[slug];
                  return (
                    <button class="module-chip" data-slug={slug} data-system={m.system} data-new={m.isNew ? 'true' : 'false'} style={`background: ${z.color}33; color: ${z.color};`}>
                      <span class="module-chip-icon">{m.icon}</span>
                      {m.nameEn}
                    </button>
                  );
                })}
              </div>
            </div>
          );
        })()}


        <!-- Print Legend (visible only in print) -->
        <div class="print-legend">
          {ZONES.map(z => (
            <div class="print-legend-item">
              <div class="print-legend-dot" style={`background: ${z.color};`}></div>
              <span>{z.label} ({z.labelTh})</span>
            </div>
          ))}
          <div class="print-legend-item" style="font-weight:700;">| Systems:</div>
          {SYSTEMS.map(s => (
            <div class="print-legend-item">
              <div class="print-legend-dot" style={`background: ${s.color};`}></div>
              <span>{s.shortLabel}</span>
            </div>
          ))}
        </div>

      </div>

      <!-- Mobile: backdrop + toggle button -->
      <div class="panel-backdrop" id="panel-backdrop"></div>
      <button class="mobile-info-toggle" id="mobile-info-toggle" aria-label="Show module info">&#x2139;</button>

      <!-- Info Panel -->
      <div class="info-panel" id="info-panel">
        <button class="panel-close" id="panel-close" aria-label="Close panel">&times;</button>
        <div class="info-default" id="info-default">
          <div class="hint-icon">&#x1F447;</div>
          <p>Click any module chip<br/>to see details</p>
        </div>
        <div class="info-module" id="info-module">
          <div class="info-module-header">
            <span class="info-module-icon" id="info-icon"></span>
            <div class="info-module-names">
              <h2 id="info-name-en"></h2>
              <p class="name-th" id="info-name-th"></p>
            </div>
          </div>
          <div class="info-system-line" id="info-system-line">
            <span class="system-dot"></span>
            <span id="info-system-label"></span>
          </div>
          <div class="info-embedded-note" id="info-embedded-note" style="display:none"></div>
          <p class="info-purpose" id="info-purpose"></p>

          <div>
            <div class="info-section-title">Key Screens</div>
            <ul class="info-list" id="info-screens"></ul>
          </div>

          <div>
            <div class="info-section-title">Primary Workflow</div>
            <ol class="info-step-list" id="info-workflow"></ol>
          </div>

          <div>
            <div class="info-section-title">Connected Modules</div>
            <div class="info-connected" id="info-connected"></div>
          </div>

          <a class="info-wiki-link" id="info-wiki-link" href="#">
            &#x2192; View full page
          </a>
        </div>

        <!-- Entry-point variant (touchpoint actor) -->
        <div class="info-entrypoint" id="info-entrypoint" style="display:none">
          <div class="info-module-header">
            <span class="info-module-icon" id="info-ep-icon"></span>
            <div class="info-module-names">
              <h2 id="info-ep-name-en"></h2>
              <p class="name-th" id="info-ep-name-th"></p>
            </div>
          </div>
          <div class="info-system-line" id="info-ep-system-line">
            <span class="system-dot"></span>
            <span id="info-ep-system-label"></span>
          </div>
          <p class="info-purpose" id="info-ep-description"></p>
          <div id="info-ep-links-section" style="display:none">
            <div class="info-section-title">Download</div>
            <div class="info-connected" id="info-ep-links"></div>
          </div>
        </div>

        <!-- Legend (always at bottom) -->
        <div class="legend">
          <div class="legend-title">Zone Legend</div>
          <div class="legend-items">
            {ZONES.map(z => (
              <div class="legend-item">
                <div class="legend-dot" style={`background: ${z.color};`}></div>
                <span>{z.label} &mdash; {z.labelTh}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script define:vars={{ FLOW_MODULES, ZONES, SYSTEMS, ENTRY_POINTS }}>
    // Build lookup
    const modulesBySlug = {};
    FLOW_MODULES.forEach(m => { modulesBySlug[m.slug] = m; });

    const zonesByModule = {};
    ZONES.forEach(z => {
      z.modules.forEach(slug => { zonesByModule[slug] = z; });
    });

    // DOM refs
    const infoDefault = document.getElementById('info-default');
    const infoModule = document.getElementById('info-module');
    const infoIcon = document.getElementById('info-icon');
    const infoNameEn = document.getElementById('info-name-en');
    const infoNameTh = document.getElementById('info-name-th');
    const infoPurpose = document.getElementById('info-purpose');
    const infoScreens = document.getElementById('info-screens');
    const infoWorkflow = document.getElementById('info-workflow');
    const infoConnected = document.getElementById('info-connected');
    const infoWikiLink = document.getElementById('info-wiki-link');

    let selectedSlug = null;

    function showEntryPoint(slug) {
      const ep = ENTRY_POINTS.find(e => e.slug === slug);
      if (!ep) return;

      // Update selected state
      document.querySelectorAll('.module-chip, .entry-point-chip').forEach(el => {
        el.classList.toggle(
          'selected',
          el.getAttribute('data-entrypoint') === slug,
        );
      });

      infoDefault.style.display = 'none';
      infoModule.classList.remove('active');
      const epPanel = document.getElementById('info-entrypoint');
      if (epPanel) epPanel.style.display = 'flex';

      document.getElementById('info-ep-icon').textContent = ep.icon;
      document.getElementById('info-ep-name-en').textContent = ep.nameEn;
      document.getElementById('info-ep-name-th').textContent = ep.nameTh;
      document.getElementById('info-ep-description').textContent = ep.description;

      const sysLine = document.getElementById('info-ep-system-line');
      const sysLabel = document.getElementById('info-ep-system-label');
      if (ep.system === 'external') {
        sysLine.className = 'info-system-line';
        sysLine.querySelector('.system-dot').style.background = '#94a3b8';
        sysLabel.textContent = 'External / Real-world';
      } else {
        const sys = SYSTEMS.find(s => s.id === ep.system);
        sysLine.className = 'info-system-line ' + (sys ? sys.id : '');
        sysLine.querySelector('.system-dot').style.background = '';
        sysLabel.textContent = sys ? sys.label : ep.system;
      }

      const linksSection = document.getElementById('info-ep-links-section');
      const linksContainer = document.getElementById('info-ep-links');
      linksContainer.innerHTML = '';
      if (ep.externalLinks && ep.externalLinks.length) {
        linksSection.style.display = 'block';
        ep.externalLinks.forEach(l => {
          const a = document.createElement('a');
          a.href = l.url;
          a.target = '_blank';
          a.rel = 'noopener';
          a.className = 'info-connected-chip';
          a.textContent = l.label;
          linksContainer.appendChild(a);
        });
      } else {
        linksSection.style.display = 'none';
      }
    }

    function showModule(slug) {
      const mod = modulesBySlug[slug];
      if (!mod) return;

      selectedSlug = slug;

      // Hide entry-point panel when switching to a module
      const epPanel = document.getElementById('info-entrypoint');
      if (epPanel) epPanel.style.display = 'none';

      // Update selected state
      document.querySelectorAll('.module-chip').forEach(el => {
        el.classList.toggle('selected', el.getAttribute('data-slug') === slug);
      });

      // Show info
      infoDefault.style.display = 'none';
      infoModule.classList.add('active');

      infoIcon.textContent = mod.icon;
      infoNameEn.textContent = mod.nameEn;
      infoNameTh.textContent = mod.nameTh;

      // System line
      const sys = SYSTEMS.find(s => s.id === mod.system);
      const sysLine = document.getElementById('info-system-line');
      const sysLabel = document.getElementById('info-system-label');
      const embedNote = document.getElementById('info-embedded-note');
      if (sys && sysLine && sysLabel) {
        sysLine.className = 'info-system-line ' + sys.id;
        sysLabel.textContent = sys.label;
      }
      if (embedNote) {
        if (mod.embeddedIn) {
          embedNote.style.display = 'block';
          embedNote.textContent = 'แอปแพทย์ฝังใน MEDHIS · แอปคนไข้ = หมอพระจอม';
        } else {
          embedNote.style.display = 'none';
        }
      }

      infoPurpose.textContent = mod.purpose;

      // Key screens
      infoScreens.innerHTML = '';
      mod.keyScreens.forEach(s => {
        const li = document.createElement('li');
        li.textContent = s;
        infoScreens.appendChild(li);
      });

      // Workflow
      infoWorkflow.innerHTML = '';
      mod.primaryWorkflow.forEach(s => {
        const li = document.createElement('li');
        li.textContent = s;
        infoWorkflow.appendChild(li);
      });

      // Connected modules
      infoConnected.innerHTML = '';
      mod.connectedModules.forEach(cs => {
        const cm = modulesBySlug[cs];
        if (!cm) return;
        const zone = zonesByModule[cs];
        const btn = document.createElement('button');
        btn.className = 'info-connected-chip';
        btn.textContent = cm.icon + ' ' + cm.nameEn;
        if (zone) {
          btn.style.borderLeft = '3px solid ' + zone.color;
        }
        btn.addEventListener('click', () => showModule(cs));
        infoConnected.appendChild(btn);
      });

      // Wiki link
      infoWikiLink.href = mod.wikiUrl;
    }

    // Mobile panel controls
    const infoPanel = document.getElementById('info-panel');
    const panelBackdrop = document.getElementById('panel-backdrop');
    const mobileToggle = document.getElementById('mobile-info-toggle');
    const panelClose = document.getElementById('panel-close');

    function openPanel() {
      infoPanel.classList.add('open');
      panelBackdrop.classList.add('open');
    }
    function closePanel() {
      infoPanel.classList.remove('open');
      panelBackdrop.classList.remove('open');
    }

    mobileToggle.addEventListener('click', openPanel);
    panelClose.addEventListener('click', closePanel);
    panelBackdrop.addEventListener('click', closePanel);

    // Attach click handlers
    document.querySelectorAll('.module-chip').forEach(el => {
      el.addEventListener('click', () => {
        const slug = el.getAttribute('data-slug');
        showModule(slug);
        // Auto-open panel on mobile when a chip is clicked
        if (window.innerWidth <= 768) {
          openPanel();
        }
      });
    });

    document.querySelectorAll('.entry-point-chip').forEach(el => {
      el.addEventListener('click', () => {
        const slug = el.getAttribute('data-entrypoint');
        showEntryPoint(slug);
        if (window.innerWidth <= 768) {
          openPanel();
        }
      });
    });
  </script>
</body>
</html>
