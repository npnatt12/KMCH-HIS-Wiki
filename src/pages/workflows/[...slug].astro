---
import { getCollection } from 'astro:content';
import ArticleV2 from '../../layouts/ArticleV2.astro';
import Breadcrumb from '../../components/article/Breadcrumb.astro';
import MetaStrip from '../../components/article/MetaStrip.astro';
import RelatedSection from '../../components/article/RelatedSection.astro';
import PrintButton from '../../components/PrintButton.astro';
import { getRelated } from '../../lib/article-helpers';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const entries = await getCollection('workflows');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
    return { params: { slug }, props: { entry } };
  });
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await entry.render();

const svgPath = join(process.cwd(), 'public', 'charts', `${slug}.svg`);
const hasSvg = existsSync(svgPath);
const svgContent = hasSvg ? readFileSync(svgPath, 'utf-8') : null;

const related = await getRelated('workflows', slug!, entry.data.roles);
---
<ArticleV2 title={entry.data.title} route="workflow">
  <Breadcrumb items={[
    { label: 'Workflows', href: '/' },
    { label: entry.data.title },
  ]} />

  <article class="kmch-prose">
    <h1>{entry.data.title}</h1>
    <MetaStrip
      type="workflow"
      roles={entry.data.roles}
      verifiedOn={entry.data['verified-on-uat']}
      sources={entry.data.sources}
      updated={entry.data.updated}
    />

    {hasSvg && svgContent && (
      <figure class="my-6 bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-4 overflow-x-auto not-prose">
        <Fragment set:html={svgContent} />
        <figcaption class="text-xs text-[var(--color-ink-muted)] mt-2 text-center">Workflow flowchart</figcaption>
      </figure>
    )}

    <Content />

    <div class="mt-8 not-prose">
      <PrintButton slug={`workflow/${slug}`} />
    </div>
  </article>

  <RelatedSection items={related} />
</ArticleV2>

<script is:inline>
  // Workflow step pattern enhancement: any H3 starting with "Step <n>" or "ขั้นตอน <n>" gets numbered badge.
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.kmch-prose h3').forEach((h3) => {
      const t = h3.textContent || '';
      const m = t.match(/^\s*(?:Step|ขั้นตอนที่|ขั้นตอน)\s+(\d+)/i);
      if (m) {
        h3.classList.add('kmch-step');
        h3.setAttribute('data-step', m[1]);
        // Strip the number from text since the badge shows it
        const node = h3.firstChild;
        if (node && node.nodeType === Node.TEXT_NODE) {
          node.textContent = t.replace(/^\s*(?:Step|ขั้นตอนที่|ขั้นตอน)\s+\d+\s*[:\-—.\s]\s*/i, '');
        }
      }
    });
  });
</script>
