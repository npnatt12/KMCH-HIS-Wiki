---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PrintButton from '../../components/PrintButton.astro';
import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

export async function getStaticPaths() {
  const entries = await getCollection('workflows');
  return entries.map((entry) => {
    const slug = entry.id.replace(/\.md$/, '').toLowerCase().replace(/\s+/g, '-');
    return {
      params: { slug },
      props: { entry },
    };
  });
}

const { entry } = Astro.props;
const { slug } = Astro.params;
const { Content } = await entry.render();

const svgPath = join(process.cwd(), 'public', 'charts', `${slug}.svg`);
const hasSvg = existsSync(svgPath);
const svgContent = hasSvg ? readFileSync(svgPath, 'utf-8') : null;
---
<Base title={entry.data.title} showBackLink={true}>
  <div class="mb-6">
    <div class="flex items-center justify-between flex-wrap gap-2 mb-1">
      <div class="flex items-center gap-2">
        <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-green-100 text-green-700">Workflow</span>
      </div>
      <PrintButton slug={`workflow/${slug}`} />
    </div>
    <h1 class="text-2xl font-bold text-gray-900">{entry.data.title}</h1>
  </div>

  {hasSvg && svgContent && (
    <div class="mb-6 bg-white border border-gray-200 rounded-lg p-4 overflow-x-auto">
      <Fragment set:html={svgContent} />
    </div>
  )}

  <div
    data-pagefind-body
    class="prose prose-sm max-w-none
           prose-headings:text-gray-800 prose-h2:text-lg prose-h2:font-bold prose-h2:border-b prose-h2:border-gray-200 prose-h2:pb-1 prose-h2:mb-3
           prose-table:text-xs prose-th:bg-gray-50 prose-td:py-1
           prose-a:text-blue-700 prose-a:no-underline hover:prose-a:underline
           prose-code:bg-gray-100 prose-code:px-1 prose-code:rounded prose-code:text-xs">
    <Content />
  </div>
</Base>
