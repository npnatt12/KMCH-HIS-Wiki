---
import { MODULE_META, MODULE_ORDER } from '../lib/modules';
const modules = MODULE_ORDER.map(slug => MODULE_META[slug]);
---
<div class="grid grid-cols-3 sm:grid-cols-4 lg:grid-cols-6 gap-3 mt-6">
  {modules.map(mod => (
    <a href={`/modules/${mod.slug}/`}
       class="flex flex-col items-center gap-1 rounded-xl p-4 transition-transform hover:scale-105 active:scale-95 min-h-[80px] justify-center"
       style={`background-color: ${mod.bgColor};`}>
      <span class="text-2xl">{mod.icon}</span>
      <span class="text-xs font-bold" style={`color: ${mod.color};`}>{mod.nameEn}</span>
      <span class="text-[10px] text-gray-500">{mod.nameTh}</span>
    </a>
  ))}
</div>
