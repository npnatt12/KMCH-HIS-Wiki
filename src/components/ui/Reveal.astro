---
interface Props {
  delay?: number;        // ms
  as?: keyof HTMLElementTagNameMap;
  class?: string;
}
const { delay = 0, as: Tag = 'div', class: className = '' } = Astro.props;
const style = delay > 0 ? `--reveal-delay: ${delay}ms;` : undefined;
---
<Tag data-reveal class={className} style={style}>
  <slot />
</Tag>
