---
import LogoLockup from '../ui/LogoLockup.astro';
import RoleSwitcher from './RoleSwitcher.astro';
interface Props { activeRole?: string; }
const { activeRole } = Astro.props;
---
<header class="sticky top-0 z-40 bg-[var(--color-bg)]/85 backdrop-blur-md border-b border-[var(--color-border)]">
  <div class="mx-auto max-w-[1200px] px-4 lg:px-6 h-14 flex items-center justify-between gap-3">
    <a href="/" class="flex items-center gap-2 shrink-0"><LogoLockup height={28} /></a>
    <div class="flex items-center gap-2">
      <RoleSwitcher activeSlug={activeRole} />
      <a href="/rooms/" class="hidden sm:inline-flex px-3 py-1.5 text-sm rounded-full hover:bg-[var(--color-surface-tint)]">Rooms</a>
      <a href="/faq/" class="hidden sm:inline-flex px-3 py-1.5 text-sm rounded-full hover:bg-[var(--color-surface-tint)]">FAQ</a>
      <a href="/master-flow/" class="hidden sm:inline-flex px-3 py-1.5 text-sm rounded-full hover:bg-[var(--color-surface-tint)]">🗺️ Master Flow</a>
    </div>
  </div>
</header>
