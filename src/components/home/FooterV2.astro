---
import LogoLockup from '../ui/LogoLockup.astro';
---
<footer class="py-12 border-t border-[var(--color-border)] bg-[var(--color-bg-strong)]">
  <div class="mx-auto px-4" style="max-width: min(calc(100% - 32px), 1080px);">
    <div class="flex flex-col lg:flex-row justify-between gap-8">
      <div>
        <LogoLockup height={32} mono />
        <p class="mt-3 text-sm text-[var(--color-ink-muted)] max-w-xs">
          KMCH HIS Wiki — คู่มือ MEDHIS สำหรับบุคลากร King Mongkut Chaokhun Thahan Hospital
        </p>
      </div>
      <div class="flex gap-8 text-sm">
        <a href="/master-flow/" class="hover:underline">Master Flow</a>
        <a href="/faq/" class="hover:underline">FAQ</a>
      </div>
    </div>
    <div class="mt-12 pt-6 border-t border-[var(--color-border)] text-xs text-[var(--color-ink-muted)] flex justify-between">
      <span>© {new Date().getFullYear()} KMCH HIS Wiki</span>
      <span>Built with Claude Code</span>
    </div>
  </div>
</footer>
