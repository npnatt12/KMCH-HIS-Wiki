---
import { ROLES } from '../../lib/roles';
import EyebrowPill from '../ui/EyebrowPill.astro';
import Card from '../ui/Card.astro';
import Reveal from '../ui/Reveal.astro';
---
<section class="py-24 lg:py-[120px]">
  <div class="mx-auto px-4" style="max-width: min(calc(100% - 32px), 1080px);">
    <Reveal>
      <EyebrowPill>เลือกตามบทบาท / BY ROLE</EyebrowPill>
      <h2 class="mt-4 text-[clamp(1.6rem,3.4vw,2.5rem)] font-semibold tracking-tight">เริ่มจากบทบาทของคุณ</h2>
      <p class="mt-2 text-[var(--color-ink-muted)]">8 บทบาทที่ใช้งาน MEDHIS</p>
    </Reveal>
    <div class="mt-10 grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
      {ROLES.map((r, idx) => (
        <Reveal delay={idx * 100}>
          <Card href={`/roles/${r.slug}/`}>
            <div class="w-12 h-12 rounded-2xl flex items-center justify-center text-base font-bold mb-4" style={`background:${r.accent}15;color:${r.accent}`}>
              {r.nameEn.split(' ').map(w => w[0]).join('').slice(0, 2).toUpperCase()}
            </div>
            <h3 class="text-lg font-semibold">{r.nameEn}</h3>
            <p class="text-sm text-[var(--color-ink-muted)]">{r.nameTh}</p>
            <p class="mt-3 text-sm text-[var(--color-ink-muted)] leading-relaxed">{r.description}</p>
            {r.tier === 2 && <span class="mt-3 inline-block text-[10px] uppercase tracking-wider" style="color: var(--color-warning);">tier 2 — pending</span>}
          </Card>
        </Reveal>
      ))}
    </div>
  </div>
</section>
