---
import { MODULE_META, MODULE_ORDER } from '../../lib/modules';
import EyebrowPill from '../ui/EyebrowPill.astro';
import Reveal from '../ui/Reveal.astro';
const modules = MODULE_ORDER.map(s => MODULE_META[s]);
---
<section class="py-24 lg:py-[120px] bg-[var(--color-bg-strong)]">
  <div class="mx-auto px-4" style="max-width: min(calc(100% - 32px), 1080px);">
    <Reveal>
      <EyebrowPill>เลือกตามโมดูล / BY MODULE</EyebrowPill>
      <h2 class="mt-4 text-[clamp(1.6rem,3.4vw,2.5rem)] font-semibold tracking-tight">หรือเลือกจากโมดูล MEDHIS ทั้ง 18</h2>
    </Reveal>
    <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-3">
      {modules.map((m, idx) => (
        <Reveal delay={idx * 30}>
          <a href={`/modules/${m.slug}/`} class="block bg-[var(--color-surface)] border border-[var(--color-border)] rounded-2xl p-4 shadow-[var(--shadow-card)] kmch-hover-lift">
            <div class="w-10 h-10 rounded-xl flex items-center justify-center text-xl mb-2" style={`background:${m.bgColor};color:${m.color}`}>{m.icon}</div>
            <div class="text-sm font-medium">{m.nameEn}</div>
            <div class="text-xs text-[var(--color-ink-muted)]">{m.nameTh}</div>
          </a>
        </Reveal>
      ))}
    </div>
  </div>
</section>
