---
import EyebrowPill from '../ui/EyebrowPill.astro';
import LogoLockup from '../ui/LogoLockup.astro';
import TroubleshootSearch from '../TroubleshootSearch.astro';
---
<section class="relative pt-24 pb-16 lg:pt-[120px] lg:pb-24" style="background: linear-gradient(180deg, var(--color-bg) 0%, color-mix(in srgb, var(--color-accent-soft) 40%, var(--color-bg)) 100%);">
  <div class="mx-auto px-4" style="max-width: min(calc(100% - 32px), 1080px);">
    <div class="text-center">
      <EyebrowPill class="mx-auto">MEDHIS HOSPITAL INFORMATION SYSTEM</EyebrowPill>
      <div class="mt-8 flex justify-center"><LogoLockup height={240} class="max-w-[60vw] h-auto" /></div>
      <h1 class="mt-8 text-[clamp(2.2rem,5.5vw,3.5rem)] font-semibold leading-tight tracking-tight">
        ค้นหาวิธีแก้ปัญหา MEDHIS
      </h1>
      <p class="mt-3 text-[var(--color-ink-muted)] text-base">
        คู่มือสำหรับบุคลากร KMCH — ค้นหาตามบทบาทหรือโมดูล
      </p>
    </div>
    <div class="mt-10 max-w-2xl mx-auto">
      <TroubleshootSearch id="home-search" />
    </div>
    <div class="mt-8 flex flex-wrap justify-center gap-4 text-sm text-[var(--color-ink-muted)]">
      <span class="px-4 py-2 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">104 หน้า</span>
      <span class="px-4 py-2 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">1,042 ภาพ</span>
      <span class="px-4 py-2 rounded-full bg-[var(--color-surface-tint)] border border-[var(--color-border)]">42 ผังงาน</span>
    </div>
  </div>
</section>
