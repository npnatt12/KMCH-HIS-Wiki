---
interface ImageItem {
  file: string;
  thumb: string;
  section?: string;
  caption?: string;
}

interface Props {
  images: ImageItem[];
  moduleSlug: string;
  countLabel?: string;
}

const { images, moduleSlug, countLabel } = Astro.props;
const count = images.length;
const displayed = countLabel ?? String(count);
const imageListJson = JSON.stringify(
  images.map((img) => ({
    full: '/' + img.file,
    thumb: '/' + img.thumb,
    caption: img.caption ?? img.section ?? '',
  })),
);
---

{count > 0 && (
  <button
    type="button"
    class="inline-flex items-center gap-2 min-h-[44px] px-4 py-2 bg-blue-50 text-blue-700 border border-blue-200 rounded-lg text-sm font-medium hover:bg-blue-100 transition-colors"
    data-gallery-images={imageListJson}
    onclick="window.openLightbox(JSON.parse(this.dataset.galleryImages), 0)"
  >
    <span class="text-lg">&#128247;</span>
    <span>ดูภาพ ({displayed})</span>
  </button>
)}
