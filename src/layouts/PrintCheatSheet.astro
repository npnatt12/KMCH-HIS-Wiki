---
interface Props {
  title: string;
  titleTh: string;
  icon?: string;
  source?: string;
  slug: string;
  type: 'module' | 'workflow';
}
import { SITE } from '../lib/site';

const { title, titleTh, icon = '', source = '', slug, type } = Astro.props;
const today = new Date().toLocaleDateString('th-TH', { year: 'numeric', month: 'long', day: 'numeric' });
const backUrl = type === 'workflow' ? `/workflows/${slug}/` : `/modules/${slug}/`;

import { existsSync, readFileSync } from 'node:fs';
import { join } from 'node:path';

// Try multiple chart name patterns
const chartSlug = slug.replace('workflow/', '');
const chartsDir = join(process.cwd(), 'public', 'charts');
const candidates = [
  `${chartSlug}.svg`,
  `${chartSlug}-module.svg`,
  `${chartSlug}-workflow.svg`,
];
const svgFile = candidates.find(f => existsSync(join(chartsDir, f)));
const rawSvg = svgFile ? readFileSync(join(chartsDir, svgFile), 'utf-8') : null;

// Process SVG: strip Mermaid dimensions, pad viewBox to match gold standard ratio
// Gold standard: appointment-registration at 509×427 ≈ 1.19:1 (w:h)
const TARGET_RATIO = 1.19;
let svgContent: string | null = null;
if (rawSvg) {
  let svg = rawSvg
    .replace(/style="[^"]*max-width[^"]*"/, '')
    .replace(/\s+width="[^"]*"/, '')
    .replace(/\s+height="[^"]*"/, '');
  // Pad narrow/tall viewBoxes so nodes appear proportionally smaller
  const vbMatch = svg.match(/viewBox="([\d.\-]+)\s+([\d.\-]+)\s+([\d.]+)\s+([\d.]+)"/);
  if (vbMatch) {
    const [, xStr, yStr, wStr, hStr] = vbMatch;
    const x = parseFloat(xStr), y = parseFloat(yStr);
    const w = parseFloat(wStr), h = parseFloat(hStr);
    const currentRatio = w / h;
    if (currentRatio < TARGET_RATIO) {
      const newW = h * TARGET_RATIO;
      const offsetX = x - (newW - w) / 2;
      svg = svg.replace(vbMatch[0], `viewBox="${offsetX} ${y} ${newW} ${h}"`);
    }
  }
  svgContent = svg;
}
---
<!DOCTYPE html>
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {SITE.cheatSheetName}</title>
    <style>
      @font-face {
        font-family: 'Sarabun';
        font-style: normal;
        font-weight: 400;
        font-display: swap;
        src: url('/fonts/Sarabun-Regular.woff2') format('woff2');
      }
      @font-face {
        font-family: 'Sarabun';
        font-style: normal;
        font-weight: 700;
        font-display: swap;
        src: url('/fonts/Sarabun-Bold.woff2') format('woff2');
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Sarabun', sans-serif;
        font-size: 7.5pt;
        color: #111;
        background: #fff;
        line-height: 1.35;
      }

      /* ---- Screen preview ---- */
      @media screen {
        body { background: #e5e7eb; padding: 2rem; }
        .no-print-bar {
          max-width: 210mm;
          margin: 0 auto 1rem;
          display: flex;
          align-items: center;
          gap: 1rem;
        }
        .print-btn {
          display: inline-flex; align-items: center; gap: 0.5rem;
          padding: 0.4rem 1rem; background: #1e40af; color: #fff;
          border: none; border-radius: 6px; cursor: pointer;
          font-family: inherit; font-size: 0.85rem;
        }
        .print-btn:hover { background: #1d4ed8; }
        .back-link { font-size: 0.85rem; color: #3b82f6; text-decoration: none; }
        .back-link:hover { text-decoration: underline; }
        .page {
          width: 210mm;
          height: 297mm;
          margin: 0 auto;
          background: #fff;
          padding: 10mm;
          box-shadow: 0 4px 20px rgba(0,0,0,0.15);
          border-radius: 4px;
          display: flex;
          flex-direction: column;
          overflow: hidden;
        }
      }

      /* ---- Print ---- */
      @media print {
        @page {
          size: A4 portrait;
          margin: 10mm;
        }
        html, body {
          width: 190mm;
          height: 277mm;
          margin: 0;
          padding: 0;
          overflow: hidden;
        }
        .no-print-bar {
          display: none !important;
          position: absolute;
          width: 0; height: 0;
          overflow: hidden;
        }
        .page {
          width: 190mm;
          height: 277mm;
          padding: 0;
          margin: 0;
          display: flex;
          flex-direction: column;
          overflow: hidden;
          page-break-inside: avoid;
          break-inside: avoid;
        }
        /* Kill any second page */
        .page ~ * {
          display: none !important;
        }
      }

      /* ---- Header (compact) ---- */
      .cs-header {
        display: flex;
        align-items: center;
        gap: 0.4rem;
        border-bottom: 2px solid #1e40af;
        padding-bottom: 2px;
        margin-bottom: 3px;
        flex: 0 0 auto;
      }
      .cs-header-icon { font-size: 1.2rem; line-height: 1; }
      .cs-header-text h1 {
        font-size: 10pt;
        font-weight: 700;
        color: #1e3a8a;
        line-height: 1.15;
      }
      .cs-header-text p {
        font-size: 6pt;
        color: #6b7280;
        margin-top: 1px;
      }

      /* ---- Flowchart (hero, proportional) ---- */
      .cs-chart {
        flex: 1 1 auto;
        min-height: 0;
        max-height: 160mm;
        overflow: hidden;
        border: 1px solid #d1d5db;
        border-radius: 6px;
        padding: 8px;
        margin-bottom: 3px;
        background: #fafbfc;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .cs-chart svg {
        display: block;
        max-width: 100%;
        max-height: 100%;
        width: auto;
        height: auto;
      }

      /* ---- Content (fills remaining) ---- */
      .cs-content {
        flex: 1 1 auto;
        overflow: hidden;
        columns: 2;
        column-gap: 5mm;
        column-rule: 1px solid #e5e7eb;
      }
      .cs-content h2 {
        font-size: 7.5pt;
        font-weight: 700;
        color: #1e3a8a;
        border-bottom: 1px solid #bfdbfe;
        padding-bottom: 1px;
        margin-top: 0.3em;
        margin-bottom: 0.1em;
        break-after: avoid;
      }
      .cs-content h3 {
        font-size: 7pt;
        font-weight: 700;
        color: #374151;
        margin-top: 0.2em;
        margin-bottom: 0.05em;
        break-after: avoid;
      }
      .cs-content p { margin-bottom: 0.15em; }
      .cs-content ul, .cs-content ol {
        padding-left: 1em;
        margin-bottom: 0.15em;
      }
      .cs-content li { margin-bottom: 0.02em; }
      .cs-content table {
        width: 100%;
        border-collapse: collapse;
        font-size: 6.5pt;
        margin-bottom: 0.15em;
        break-inside: avoid;
      }
      .cs-content th {
        background: #f3f4f6;
        font-weight: 700;
        padding: 1px 2px;
        border: 1px solid #d1d5db;
        text-align: left;
      }
      .cs-content td {
        padding: 1px 2px;
        border: 1px solid #e5e7eb;
        vertical-align: top;
      }
      .cs-content a { color: #1d4ed8; text-decoration: none; }

      /* ---- Footer (minimal) ---- */
      .cs-footer {
        flex: 0 0 auto;
        padding-top: 2px;
        border-top: 1px solid #e5e7eb;
        font-size: 6pt;
        color: #9ca3af;
        display: flex;
        justify-content: space-between;
        align-items: center;
      }
    </style>
  </head>
  <body>
    <div class="no-print-bar">
      <a href={backUrl} class="back-link">← กลับหน้า {title}</a>
      <button class="print-btn" onclick="window.print()">🖨️ พิมพ์ / บันทึก PDF</button>
    </div>

    <div class="page">
      <header class="cs-header">
        {icon && <span class="cs-header-icon">{icon}</span>}
        <div class="cs-header-text">
          <h1>{title} — {titleTh}</h1>
          {source && <p>{source}</p>}
        </div>
      </header>

      {svgContent && (
        <div class="cs-chart">
          <Fragment set:html={svgContent} />
        </div>
      )}

      <div class="cs-content">
        <slot />
      </div>

      <footer class="cs-footer">
        <span>{SITE.name}</span>
        <span>{today}</span>
      </footer>
    </div>

    <script is:inline>
      // Force single-page print on Mac/Chrome/Safari:
      // Measure the .page, if it's taller than one A4 page, scale it down.
      // This runs BEFORE the browser lays out the print pages.
      function fitToOnePage() {
        var page = document.querySelector('.page');
        var bar = document.querySelector('.no-print-bar');
        if (!page) return;
        // Hide bar completely
        if (bar) bar.style.display = 'none';
        // Reset any previous transform
        page.style.transform = '';
        page.style.width = '';
        // Force layout recalc
        void page.offsetHeight;
        // A4 with 10mm margins = 277mm. At 96dpi, 1mm = 3.7795px
        var targetH = 277 * 3.7795275591;
        var actualH = page.scrollHeight;
        if (actualH > targetH + 2) {
          var scale = targetH / actualH;
          page.style.transformOrigin = 'top left';
          page.style.transform = 'scale(' + scale + ')';
          // Compensate width so it still fills the page width
          page.style.width = (100 / scale) + '%';
          // Set body height to exactly the scaled height to prevent second page
          document.body.style.height = targetH + 'px';
          document.body.style.overflow = 'hidden';
        }
      }
      function resetFit() {
        var page = document.querySelector('.page');
        var bar = document.querySelector('.no-print-bar');
        if (page) {
          page.style.transform = '';
          page.style.width = '';
          page.style.transformOrigin = '';
        }
        if (bar) bar.style.display = '';
        document.body.style.height = '';
        document.body.style.overflow = '';
      }
      window.addEventListener('beforeprint', fitToOnePage);
      window.addEventListener('afterprint', resetFit);
      // Also handle the print button directly for Safari which fires beforeprint late
      var printBtn = document.querySelector('.print-btn');
      if (printBtn) {
        printBtn.addEventListener('click', function(e) {
          e.preventDefault();
          fitToOnePage();
          setTimeout(function() { window.print(); }, 50);
        });
      }
    </script>
  </body>
</html>
