---
import '../styles/global.css';
import Navbar from '../components/Navbar.astro';
import Lightbox from '../components/Lightbox.astro';
import { HOSPITAL, SITE } from '../lib/site';

interface Props {
  title: string;
  showBackLink?: boolean;
}

const { title, showBackLink = false } = Astro.props;
---
<html lang="th">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title} — {SITE.name}</title>
    <meta name="description" content={SITE.description} />
    <link rel="preload" href="/fonts/Sarabun-Regular.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="preload" href="/fonts/Sarabun-Bold.woff2" as="font" type="font/woff2" crossorigin />
  </head>
  <body class="font-sans bg-gray-50 text-gray-900 min-h-screen">
    <Navbar />
    <main class="max-w-4xl mx-auto px-4 py-6">
      {showBackLink && (
        <a href="/" class="inline-flex items-center gap-1 text-sm text-blue-600 hover:text-blue-800 mb-4">
          ← กลับหน้าหลัก
        </a>
      )}
      <slot />
    </main>
    <footer class="max-w-4xl mx-auto px-4 py-8 text-center text-xs text-gray-400">
      {SITE.name} • {HOSPITAL.nameTh} • สร้างจากคู่มือ MEDHIS • {new Date().getFullYear()}
    </footer>
    <Lightbox />
    <script>
      import '../lib/reveal';
    </script>
    <script src="/search-ui.js" defer></script>
  </body>
</html>
